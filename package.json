{
  "name": "sema",
  "displayName": "Sema",
  "description": "Language support for Sema, a Lisp dialect with first-class LLM primitives",
  "version": "0.2.0",
  "publisher": "helgesverre",
  "author": {
    "name": "Helge Sverre",
    "email": "helge.sverre@gmail.com"
  },
  "license": "MIT",
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sema",
    "onCustomEditor:sema.notebook",
    "onDebugResolve:sema"
  ],
  "homepage": "https://sema-lang.com",
  "bugs": {
    "url": "https://github.com/sema-lisp/vscode-sema/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sema-lisp/vscode-sema"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "sema",
    "lisp",
    "llm",
    "scheme",
    "s-expression",
    "ai"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "languages": [
      {
        "id": "sema",
        "aliases": [
          "Sema",
          "sema"
        ],
        "extensions": [
          ".sema"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sema-file-light.svg",
          "dark": "./icons/sema-file-dark.svg"
        }
      },
      {
        "id": "sema-notebook",
        "aliases": [
          "Sema Notebook"
        ],
        "extensions": [
          ".sema-nb"
        ],
        "icon": {
          "light": "./icons/sema-notebook-light.svg",
          "dark": "./icons/sema-notebook-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "sema",
        "scopeName": "source.sema",
        "path": "./syntaxes/sema.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "sema.clearResults",
        "title": "Sema: Clear Inline Results"
      }
    ],
    "configuration": {
      "title": "Sema",
      "properties": {
        "sema.path": {
          "type": "string",
          "default": "sema",
          "description": "Path to the sema binary"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "sema.notebook",
        "displayName": "Sema Notebook",
        "selector": [
          {
            "filenamePattern": "*.sema-nb"
          }
        ],
        "priority": "default"
      }
    ],
    "debuggers": [
      {
        "type": "sema",
        "label": "Sema",
        "languages": [
          "sema"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the .sema file to debug.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Break on the first line of the program.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "sema",
            "request": "launch",
            "name": "Debug Sema Program",
            "program": "${file}",
            "stopOnEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "Sema: Debug Program",
            "description": "Debug the current Sema program with the sema DAP server.",
            "body": {
              "type": "sema",
              "request": "launch",
              "name": "Debug Sema Program",
              "program": "^\"\\${file}\"",
              "stopOnEntry": false
            }
          }
        ]
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "sema",
        "label": "Sema"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
